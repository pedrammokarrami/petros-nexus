{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/club/**",
              "components/core/**",
              "ui_kits/fan_club/**",
              "ui_kits/fan_club_v2/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Unbounded|Space Grotesk|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Unbounded, Space Grotesk, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|active|status|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, active, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:online|offline|live)$/]",
        "message": "<Avatar> status must be one of 'online' | 'offline' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|pulse|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, pulse, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|live|accent|outline)$/]",
        "message": "<Badge> variant must be one of 'default' | 'live' | 'accent' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bartender'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|slotId|placeholder|src|lines|speak|interval|side|size|key|ref|className|style|children)$/]",
        "message": "<Bartender> doesn't accept that prop. Declared props: name, slotId, placeholder, src, lines, speak, interval, side, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bartender'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<Bartender> side must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|disabled|block|onClick|children|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, disabled, block, onClick, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|glow)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'glow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|pad|glow|onClick|children|className|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, pad, glow, onClick, children, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|glass|stage)$/]",
        "message": "<Card> variant must be one of 'solid' | 'glass' | 'stage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChallengeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|progress|progressLabel|tag|onJoin|key|ref|className|style|children)$/]",
        "message": "<ChallengeCard> doesn't accept that prop. Declared props: title, description, progress, progressLabel, tag, onJoin."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:author|avatarSrc|children|time|persona|reactions|align|key|ref|className|style|children)$/]",
        "message": "<ChatMessage> doesn't accept that prop. Declared props: author, avatarSrc, children, time, persona, reactions, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute[name.name='persona'] > Literal[value!=/^(?:member|spotlight|dj)$/]",
        "message": "<ChatMessage> persona must be one of 'member' | 'spotlight' | 'dj'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatMessage'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<ChatMessage> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ClubStage'] > JSXAttribute > JSXIdentifier[name!=/^(?:clubName|kicker|mood|memberCount|live|children|caption|key|ref|className|style|children)$/]",
        "message": "<ClubStage> doesn't accept that prop. Declared props: clubName, kicker, mood, memberCount, live, children, caption."
      },
      {
        "selector": "JSXOpeningElement[name.name='FloatingMessage'] > JSXAttribute > JSXIdentifier[name!=/^(?:author|children|persona|avatarSrc|intensity|key|ref|className|style|children)$/]",
        "message": "<FloatingMessage> doesn't accept that prop. Declared props: author, children, persona, avatarSrc, intensity."
      },
      {
        "selector": "JSXOpeningElement[name.name='FloatingMessage'] > JSXAttribute[name.name='persona'] > Literal[value!=/^(?:member|dj|spotlight)$/]",
        "message": "<FloatingMessage> persona must be one of 'member' | 'dj' | 'spotlight'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|children|label|disabled|badge|onClick|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, children, label, disabled, badge, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|glow)$/]",
        "message": "<IconButton> variant must be one of 'primary' | 'ghost' | 'glow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|icon|suffix|size|glow|onSubmit|disabled|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, onChange, placeholder, icon, suffix, size, glow, onSubmit, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LightingFx'] > JSXAttribute > JSXIdentifier[name!=/^(?:spotlights|godRays|floorWash|mood|key|ref|className|style|children)$/]",
        "message": "<LightingFx> doesn't accept that prop. Declared props: spotlights, godRays, floorWash, mood."
      },
      {
        "selector": "JSXOpeningElement[name.name='Member'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|avatarSrc|active|status|key|ref|className|style|children)$/]",
        "message": "<Member> doesn't accept that prop. Declared props: name, avatarSrc, active, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='Member'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:online|offline|live)$/]",
        "message": "<Member> status must be one of 'online' | 'offline' | 'live'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoodMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|sampleCount|windowLabel|compact|key|ref|className|style|children)$/]",
        "message": "<MoodMeter> doesn't accept that prop. Declared props: value, sampleCount, windowLabel, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='NeonSign'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|color|size|flicker|framed|rotate|key|ref|className|style|children)$/]",
        "message": "<NeonSign> doesn't accept that prop. Declared props: children, style, color, size, flicker, framed, rotate."
      },
      {
        "selector": "JSXOpeningElement[name.name='NeonSign'] > JSXAttribute[name.name='style'] > Literal[value!=/^(?:tube|solid)$/]",
        "message": "<NeonSign> style must be one of 'tube' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NowPlaying'] > JSXAttribute > JSXIdentifier[name!=/^(?:track|artist|progress|votable|voted|onVote|key|ref|className|style|children)$/]",
        "message": "<NowPlaying> doesn't accept that prop. Declared props: track, artist, progress, votable, voted, onVote."
      },
      {
        "selector": "JSXOpeningElement[name.name='PhotoBackdrop'] > JSXAttribute > JSXIdentifier[name!=/^(?:slotId|placeholder|src|parallax|grain|tint|vignette|key|ref|className|style|children)$/]",
